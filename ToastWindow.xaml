<Window x:Class="ClaudeTray.ToastWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:ClassModifier="internal"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="False" ShowActivated="False" Topmost="True"
        ResizeMode="NoResize" WindowStartupLocation="Manual"
        Width="400" Height="200"
        FontFamily="Segoe UI Variable Text, Segoe UI">

    <Window.Resources>
        <!-- Round close affordance in the corner. -->
        <Style x:Key="Circle" TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="13">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#44FFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Root carries the entrance slide + fade (set in code-behind). -->
    <Grid x:Name="Root" Opacity="0">
        <Grid.RenderTransform>
            <TranslateTransform x:Name="SlideT" Y="44" />
        </Grid.RenderTransform>

        <Border CornerRadius="16" Margin="14">
            <Border.Effect>
                <DropShadowEffect BlurRadius="26" ShadowDepth="5" Direction="270" Opacity="0.5" Color="#80000000" />
            </Border.Effect>
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#E89072" Offset="0" />
                    <GradientStop Color="#D97757" Offset="0.5" />
                    <GradientStop Color="#B0512F" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>

            <Grid ClipToBounds="True">
                <!-- Confetti is generated in code-behind and sits above the gradient, below the text. -->
                <Canvas x:Name="Confetti" IsHitTestVisible="False" />

                <Grid Margin="22,16,16,18">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Header: party emoji + headline, close button pinned right. -->
                    <Grid Grid.Row="0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="Emoji" FontSize="32" VerticalAlignment="Center" />
                            <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                                <TextBlock x:Name="TitleText" FontSize="20" FontWeight="Bold" Foreground="White" />
                                <TextBlock x:Name="Subtitle" FontSize="13" Foreground="#EEFFFFFF"
                                           TextWrapping="Wrap" MaxWidth="270" />
                            </StackPanel>
                        </StackPanel>
                        <Button x:Name="CloseButton" Style="{StaticResource Circle}"
                                Content="✕" Width="26" Height="26" FontSize="11"
                                Background="#22FFFFFF" Foreground="White"
                                HorizontalAlignment="Right" VerticalAlignment="Top"
                                Cursor="Hand" Click="Close_Click" />
                    </Grid>

                    <!-- The good news, shown as available quota filling back up to 100%. -->
                    <StackPanel Grid.Row="1" VerticalAlignment="Center" Margin="0,12,0,0">
                        <Grid>
                            <TextBlock Text="Weekly quota left" FontSize="13" FontWeight="SemiBold"
                                       Foreground="White" HorizontalAlignment="Left" />
                            <TextBlock x:Name="AvailPct" FontSize="13" FontWeight="SemiBold"
                                       Foreground="White" HorizontalAlignment="Right" />
                        </Grid>
                        <Border Height="10" CornerRadius="5" Background="#33FFFFFF"
                                Margin="0,6,0,0" ClipToBounds="True">
                            <Border x:Name="Fill" CornerRadius="5" Background="White"
                                    HorizontalAlignment="Stretch" RenderTransformOrigin="0,0">
                                <Border.RenderTransform>
                                    <ScaleTransform x:Name="FillScale" ScaleX="0.21" />
                                </Border.RenderTransform>
                            </Border>
                        </Border>
                        <TextBlock x:Name="Caption" FontSize="12" Foreground="#CCFFFFFF"
                                   Margin="0,7,0,0" TextWrapping="Wrap" />
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
