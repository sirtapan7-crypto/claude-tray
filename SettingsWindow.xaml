<Window x:Class="ClaudeTray.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:ClassModifier="internal"
        Title="Settings"
        Width="760" Height="520"
        MinWidth="640" MinHeight="460"
        WindowStartupLocation="CenterScreen"
        ThemeMode="System"
        FontFamily="Segoe UI Variable Text, Segoe UI">

    <!-- Two columns: a fixed navigation sidebar and a content pane that fills the rest.
         The whole layout is declared here (declarative XAML) — no imperative z-order stacking,
         so what you read is exactly what renders. -->
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="216" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ===== Sidebar ===== -->
        <Border Grid.Column="0"
                Background="{DynamicResource LayerFillColorDefaultBrush}"
                BorderThickness="0,0,1,0"
                BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}">
            <StackPanel Margin="12,16,12,12">
                <TextBlock Text="Settings"
                           FontSize="20" FontWeight="SemiBold"
                           Margin="8,0,0,14"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" />

                <!-- Selected nav item: accent bar + subtle background, the Fluent NavigationView look. -->
                <Border CornerRadius="6" Padding="0" Height="40"
                        Background="{DynamicResource SubtleFillColorSecondaryBrush}">
                    <Grid>
                        <Border Width="3" CornerRadius="2" HorizontalAlignment="Left"
                                Margin="2,8,0,8"
                                Background="{DynamicResource AccentFillColorDefaultBrush}" />
                        <TextBlock Text="General" VerticalAlignment="Center"
                                   Margin="16,0,0,0" FontSize="14"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                    </Grid>
                </Border>
            </StackPanel>
        </Border>

        <!-- ===== Content ===== -->
        <Grid Grid.Column="1" Margin="32,28,32,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" /><!-- Refresh header -->
                <RowDefinition Height="Auto" /><!-- Refresh caption -->
                <RowDefinition Height="Auto" /><!-- Interval card -->
                <RowDefinition Height="Auto" /><!-- Display header -->
                <RowDefinition Height="Auto" /><!-- Display card -->
                <RowDefinition Height="*" />   <!-- spacer -->
                <RowDefinition Height="Auto" /><!-- footer -->
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Refresh"
                       FontSize="16" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
            <TextBlock Grid.Row="1" Text="How often the tray checks your Claude usage."
                       Margin="0,2,0,12"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />

            <!-- Interval card -->
            <Border Grid.Row="2" CornerRadius="8" Padding="16,12"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Interval" VerticalAlignment="Center"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                    <Slider Grid.Column="1" x:Name="IntervalSlider"
                            Margin="20,0,16,0" VerticalAlignment="Center"
                            Minimum="0.5" Maximum="60"
                            TickFrequency="0.5" IsSnapToTickEnabled="True"
                            ValueChanged="IntervalSlider_ValueChanged" />
                    <TextBlock Grid.Column="2" x:Name="IntervalValue"
                               VerticalAlignment="Center" MinWidth="72"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                </Grid>
            </Border>

            <TextBlock Grid.Row="3" Text="Display"
                       FontSize="16" FontWeight="SemiBold" Margin="0,22,0,12"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />

            <!-- Display card -->
            <Border Grid.Row="4" CornerRadius="8" Padding="16,12"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}">
                <CheckBox x:Name="ShowPctCheck"
                          Content="Show the usage percentage on the icon"
                          Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
            </Border>

            <!-- ===== Footer ===== -->
            <Grid Grid.Row="6" Margin="0,16,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" x:Name="VersionText"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="CancelButton" Content="Cancel"
                            MinWidth="92" Padding="14,6" Margin="0,0,8,0"
                            Click="Cancel_Click" />
                    <Button x:Name="SaveButton" Content="Save"
                            MinWidth="92" Padding="14,6"
                            Style="{DynamicResource AccentButtonStyle}"
                            Click="Save_Click" />
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Window>
