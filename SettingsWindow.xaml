<Window x:Class="ClaudeTray.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ClaudeTray"
        x:ClassModifier="internal"
        Title="Settings"
        Width="760" Height="600"
        MinWidth="640" MinHeight="560"
        WindowStartupLocation="CenterScreen"
        ThemeMode="System"
        FontFamily="Segoe UI Variable Text, Segoe UI">

    <Window.Resources>
        <!-- A clickable info card on the About page: lifts and accents its border on hover so it
             reads as a link, not a static panel. The URL is carried in each card's Tag. -->
        <Style x:Key="LinkCard" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundFillColorDefaultBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource CardStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="14,12" />
            <Setter Property="Cursor" Value="Hand" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource CardBackgroundFillColorSecondaryBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentFillColorDefaultBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Translucent pill used for the version / platform tags over the hero gradient. -->
        <Style x:Key="HeroChip" TargetType="Border">
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="10,3" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Background" Value="#30FFFFFF" />
        </Style>

        <!-- ===== Settings-row pattern (Fluent "SettingsCard"): a section is a small caps header
             over a GroupCard whose children are SettingsRows (label+description left, control right),
             split by RowDividers. ===== -->

        <!-- Small muted label that titles a group of rows. -->
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="2,22,0,8" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorTertiaryBrush}" />
        </Style>

        <!-- The rounded container that holds one or more rows. -->
        <Style x:Key="GroupCard" TargetType="Border">
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Background" Value="{DynamicResource CardBackgroundFillColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{DynamicResource CardStrokeColorDefaultBrush}" />
        </Style>

        <!-- A hairline between rows, inset to align with the rows' text. -->
        <Style x:Key="RowDivider" TargetType="Border">
            <Setter Property="Height" Value="1" />
            <Setter Property="Margin" Value="16,0" />
            <Setter Property="Background" Value="{DynamicResource DividerStrokeColorDefaultBrush}" />
        </Style>

        <!-- The row itself: title + optional description on the left, trailing control on the right. -->
        <Style TargetType="{x:Type local:SettingsRow}">
            <Setter Property="Padding" Value="16,13" />
            <Setter Property="HorizontalContentAlignment" Value="Right" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type local:SettingsRow}">
                        <Grid Margin="{TemplateBinding Padding}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,20,0">
                                <TextBlock Text="{TemplateBinding Header}"
                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                <TextBlock x:Name="Desc" Text="{TemplateBinding Description}"
                                           Margin="0,3,0,0" FontSize="12" TextWrapping="Wrap"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                            <ContentPresenter Grid.Column="1"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <!-- No description → hide the caption line so the row stays compact. -->
                            <Trigger Property="Description" Value="">
                                <Setter TargetName="Desc" Property="Visibility" Value="Collapsed" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- A pill toggle switch (templated ToggleButton) matching the Fluent accent — the trailing
             control for every boolean setting. IsChecked drives the track color and thumb position. -->
        <Style x:Key="ToggleSwitch" TargetType="ToggleButton">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Track" Width="40" Height="22" CornerRadius="11"
                                SnapsToDevicePixels="True"
                                Background="{DynamicResource ControlAltFillColorSecondaryBrush}"
                                BorderBrush="{DynamicResource TextFillColorSecondaryBrush}"
                                BorderThickness="1">
                            <Ellipse x:Name="Thumb" Width="12" Height="12"
                                     VerticalAlignment="Center" HorizontalAlignment="Left"
                                     Margin="4,0,0,0"
                                     Fill="{DynamicResource TextFillColorSecondaryBrush}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="{DynamicResource AccentFillColorDefaultBrush}" />
                                <Setter TargetName="Track" Property="BorderBrush" Value="{DynamicResource AccentFillColorDefaultBrush}" />
                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right" />
                                <Setter TargetName="Thumb" Property="Margin" Value="0,0,4,0" />
                                <Setter TargetName="Thumb" Property="Width" Value="14" />
                                <Setter TargetName="Thumb" Property="Height" Value="14" />
                                <Setter TargetName="Thumb" Property="Fill" Value="White" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Track" Property="Opacity" Value="0.85" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Track" Property="Opacity" Value="0.4" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Two columns: a fixed navigation sidebar and a content pane that fills the rest.
         The whole layout is declared here (declarative XAML) — no imperative z-order stacking,
         so what you read is exactly what renders. -->
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="216" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ===== Sidebar ===== -->
        <Border Grid.Column="0"
                Background="{DynamicResource LayerFillColorDefaultBrush}"
                BorderThickness="0,0,1,0"
                BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}">
            <StackPanel Margin="12,16,12,12">
                <TextBlock Text="Settings"
                           FontSize="20" FontWeight="SemiBold"
                           Margin="8,0,0,14"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" />

                <!-- Nav items. Selection (accent bar + subtle background) is toggled in code-behind;
                     a transparent background keeps the whole row clickable even when unselected. -->
                <Border x:Name="NavGeneral" CornerRadius="6" Height="40" Margin="0,0,0,4"
                        Background="Transparent" Cursor="Hand"
                        MouseLeftButtonUp="Nav_Click" Tag="General">
                    <Grid>
                        <Border x:Name="AccentGeneral" Width="3" CornerRadius="2"
                                HorizontalAlignment="Left" Margin="2,8,0,8"
                                Background="{DynamicResource AccentFillColorDefaultBrush}" />
                        <TextBlock Text="General" VerticalAlignment="Center"
                                   Margin="16,0,0,0" FontSize="14"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                    </Grid>
                </Border>

                <Border x:Name="NavNotifications" CornerRadius="6" Height="40" Margin="0,0,0,4"
                        Background="Transparent" Cursor="Hand"
                        MouseLeftButtonUp="Nav_Click" Tag="Notifications">
                    <Grid>
                        <Border x:Name="AccentNotifications" Width="3" CornerRadius="2"
                                HorizontalAlignment="Left" Margin="2,8,0,8"
                                Visibility="Collapsed"
                                Background="{DynamicResource AccentFillColorDefaultBrush}" />
                        <TextBlock Text="Notifications" VerticalAlignment="Center"
                                   Margin="16,0,0,0" FontSize="14"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                    </Grid>
                </Border>

                <Border x:Name="NavAbout" CornerRadius="6" Height="40"
                        Background="Transparent" Cursor="Hand"
                        MouseLeftButtonUp="Nav_Click" Tag="About">
                    <Grid>
                        <Border x:Name="AccentAbout" Width="3" CornerRadius="2"
                                HorizontalAlignment="Left" Margin="2,8,0,8"
                                Visibility="Collapsed"
                                Background="{DynamicResource AccentFillColorDefaultBrush}" />
                        <TextBlock Text="About" VerticalAlignment="Center"
                                   Margin="16,0,0,0" FontSize="14"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                    </Grid>
                </Border>
            </StackPanel>
        </Border>

        <!-- ===== Content host: a page area (General / About overlaid, visibility-toggled) + a
             pinned footer shared by both pages. ===== -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />   <!-- page -->
                <RowDefinition Height="Auto" /><!-- footer -->
            </Grid.RowDefinitions>

            <!-- ========================= GENERAL PAGE =========================
                 Every setting is a SettingsRow (label+description left, control right) grouped
                 under a small caps section header inside a GroupCard. -->
            <Grid x:Name="GeneralPane" Grid.Row="0" Margin="32,28,32,0">
                <!-- The settings sections scroll as a group; the footer below stays pinned, so adding
                     sections never clips the Save/Cancel buttons. -->
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,14,0">
                    <StackPanel>
                        <TextBlock Text="General"
                                   FontSize="16" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                        <TextBlock Text="Polling cadence, tray display, and startup behaviour."
                                   Margin="0,2,0,4" TextWrapping="Wrap"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />

                        <!-- ===== Refresh ===== -->
                        <TextBlock Text="Refresh" Style="{StaticResource SectionHeader}" Margin="2,16,0,8" />
                        <Border Style="{StaticResource GroupCard}">
                            <local:SettingsRow Header="Interval"
                                               Description="How often the tray checks your Claude usage.">
                                <StackPanel Orientation="Horizontal">
                                    <Slider x:Name="IntervalSlider" Width="170" VerticalAlignment="Center"
                                            Minimum="0.5" Maximum="60"
                                            TickFrequency="0.5" IsSnapToTickEnabled="True"
                                            ValueChanged="IntervalSlider_ValueChanged" />
                                    <TextBlock x:Name="IntervalValue" VerticalAlignment="Center"
                                               MinWidth="72" Margin="14,0,0,0"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                </StackPanel>
                            </local:SettingsRow>
                        </Border>

                        <!-- Each refresh is a 1-token Haiku call (the "heartbeat"). This caption recalculates
                             the consumption live as the slider moves, so the cost of the chosen cadence is explicit. -->
                        <TextBlock x:Name="CostEstimate"
                                   Margin="2,10,2,0" TextWrapping="Wrap" FontSize="12"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />

                        <!-- ===== Display ===== -->
                        <TextBlock Text="Display" Style="{StaticResource SectionHeader}" />
                        <Border Style="{StaticResource GroupCard}">
                            <local:SettingsRow Header="Show percentage on the icon"
                                               Description="Draw the usage percentage number on the tray icon; otherwise just the fill bar.">
                                <ToggleButton x:Name="ShowPctCheck" Style="{StaticResource ToggleSwitch}" />
                            </local:SettingsRow>
                        </Border>

                        <!-- ===== Claude Code ===== -->
                        <TextBlock Text="Claude Code" Style="{StaticResource SectionHeader}" />
                        <Border Style="{StaticResource GroupCard}">
                            <StackPanel>
                                <local:SettingsRow Header="Working directory"
                                                   Description="Used when launching Claude Code from the tray menu, a double-click on the tray icon, or auto-open. Defaults to your home directory; clear it to reset.">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBox x:Name="DirectoryBox" Width="200"
                                                 VerticalContentAlignment="Center" Padding="8,5" />
                                        <Button x:Name="BrowseButton" Content="Browse…"
                                                MinWidth="92" Padding="14,5" Margin="8,0,0,0"
                                                Click="Browse_Click" />
                                    </StackPanel>
                                </local:SettingsRow>

                                <Border Style="{StaticResource RowDivider}" />

                                <local:SettingsRow Header="Open automatically when signed out"
                                                   Description="Launch Claude Code when a check finds you signed out, so it can refresh the expired token.">
                                    <ToggleButton x:Name="AutoOpenCheck" Style="{StaticResource ToggleSwitch}" />
                                </local:SettingsRow>

                                <Border Style="{StaticResource RowDivider}" />

                                <local:SettingsRow Header="Retry while signed out"
                                                   Description="How often to re-check your usage after a sign-out, until you authenticate again.">
                                    <StackPanel Orientation="Horizontal">
                                        <Slider x:Name="RetrySlider" Width="170" VerticalAlignment="Center"
                                                TickFrequency="5" IsSnapToTickEnabled="True"
                                                ValueChanged="RetrySlider_ValueChanged" />
                                        <TextBlock x:Name="RetryValue" VerticalAlignment="Center"
                                                   MinWidth="72" Margin="14,0,0,0"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>
                                </local:SettingsRow>
                            </StackPanel>
                        </Border>

                        <!-- ===== Startup ===== -->
                        <TextBlock Text="Startup" Style="{StaticResource SectionHeader}" />
                        <Border Style="{StaticResource GroupCard}" Margin="0,0,0,4">
                            <local:SettingsRow Header="Start with Windows"
                                               Description="Launch Claude Code Tray automatically when you sign in.">
                                <ToggleButton x:Name="StartupCheck" Style="{StaticResource ToggleSwitch}" />
                            </local:SettingsRow>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- ========================= NOTIFICATIONS PAGE =========================
                 Same SettingsRow pattern: each toggle is a row, and each routine reset's
                 "minimum usage to notify" threshold is its own row right below, dimmed
                 (IsEnabled-bound) while its toggle is off. -->
            <Grid x:Name="NotificationsPane" Grid.Row="0" Margin="32,28,32,0" Visibility="Collapsed">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,14,0">
                    <StackPanel>
                        <TextBlock Text="Notifications"
                                   FontSize="16" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                        <TextBlock Text="Which usage events show a tray notification, and how much usage is worth a heads-up."
                                   Margin="0,2,0,4" TextWrapping="Wrap"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />

                        <!-- ===== Routine resets ===== -->
                        <TextBlock Text="Routine resets" Style="{StaticResource SectionHeader}" Margin="2,16,0,8" />
                        <Border Style="{StaticResource GroupCard}">
                            <StackPanel>
                                <local:SettingsRow Header="Routine weekly reset"
                                                   Description="A calmer “fresh week, quota's back” notification when your weekly limit resets on schedule.">
                                    <ToggleButton x:Name="NotifyWeeklyCheck" Style="{StaticResource ToggleSwitch}" />
                                </local:SettingsRow>

                                <Border Style="{StaticResource RowDivider}" />

                                <local:SettingsRow Header="Minimum weekly usage to notify"
                                                   Description="Skip the weekly ping if the window was barely used before resetting."
                                                   IsEnabled="{Binding IsChecked, ElementName=NotifyWeeklyCheck}">
                                    <StackPanel Orientation="Horizontal">
                                        <Slider x:Name="WeeklyMinSlider" Width="150" VerticalAlignment="Center"
                                                Minimum="0" Maximum="100"
                                                TickFrequency="1" IsSnapToTickEnabled="True"
                                                ValueChanged="WeeklyMinSlider_ValueChanged" />
                                        <TextBlock x:Name="WeeklyMinValue" VerticalAlignment="Center"
                                                   MinWidth="40" Margin="14,0,0,0"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>
                                </local:SettingsRow>

                                <Border Style="{StaticResource RowDivider}" />

                                <local:SettingsRow Header="5-hour session reset"
                                                   Description="A “fresh session” notification when your 5-hour session window resets (can happen several times a day).">
                                    <ToggleButton x:Name="NotifySessionCheck" Style="{StaticResource ToggleSwitch}" />
                                </local:SettingsRow>

                                <Border Style="{StaticResource RowDivider}" />

                                <local:SettingsRow Header="Minimum session usage to notify"
                                                   Description="Skip the session ping if the window was barely used before resetting."
                                                   IsEnabled="{Binding IsChecked, ElementName=NotifySessionCheck}">
                                    <StackPanel Orientation="Horizontal">
                                        <Slider x:Name="SessionMinSlider" Width="150" VerticalAlignment="Center"
                                                Minimum="0" Maximum="100"
                                                TickFrequency="1" IsSnapToTickEnabled="True"
                                                ValueChanged="SessionMinSlider_ValueChanged" />
                                        <TextBlock x:Name="SessionMinValue" VerticalAlignment="Center"
                                                   MinWidth="40" Margin="14,0,0,0"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>
                                </local:SettingsRow>
                            </StackPanel>
                        </Border>

                        <!-- ===== Anomaly alerts ===== -->
                        <TextBlock Text="Anomalies" Style="{StaticResource SectionHeader}" />
                        <Border Style="{StaticResource GroupCard}" Margin="0,0,0,4">
                            <local:SettingsRow Header="Unexpected usage drop"
                                               Description="Shows a tray notification if weekly usage drops unexpectedly — resetting to 0% before its scheduled deadline, or a partial mid-window credit (e.g. 91% → 50%). The event is also saved to reset-events.log.">
                                <ToggleButton x:Name="NotifyResetCheck" Style="{StaticResource ToggleSwitch}" />
                            </local:SettingsRow>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- ========================= ABOUT PAGE ========================= -->
            <Grid x:Name="AboutPane" Grid.Row="0" Visibility="Collapsed">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <!-- HERO: full-bleed Claude clay/coral gradient with the logo, name, tagline,
                             and version/platform chips. This is the "bold" surface. -->
                        <Border MinHeight="188">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#E89072" Offset="0" />
                                    <GradientStop Color="#D97757" Offset="0.55" />
                                    <GradientStop Color="#B0512F" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                            <Grid Margin="32,26,32,26">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <!-- Logo on a soft white plate so the clay tile reads on the gradient. -->
                                    <Border Width="104" Height="104" CornerRadius="22"
                                            Background="#22FFFFFF" Padding="6">
                                        <Image x:Name="LogoImage" Width="92" Height="92"
                                               RenderOptions.BitmapScalingMode="HighQuality" />
                                    </Border>
                                    <StackPanel Margin="22,0,0,0" VerticalAlignment="Center" MaxWidth="360">
                                        <TextBlock Text="Claude Code Tray"
                                                   FontSize="29" FontWeight="Bold"
                                                   Foreground="White" TextWrapping="Wrap" />
                                        <TextBlock Text="A native Windows tray monitor for your Claude Code usage — at a glance, always on."
                                                   Margin="0,4,0,0" FontSize="13"
                                                   TextWrapping="Wrap" Foreground="#EEFFFFFF" />
                                        <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                            <Border Style="{StaticResource HeroChip}">
                                                <TextBlock x:Name="HeroVersion" Foreground="White" FontSize="12" FontWeight="SemiBold" />
                                            </Border>
                                            <Border Style="{StaticResource HeroChip}">
                                                <TextBlock Text="Windows 10 · 11" Foreground="White" FontSize="12" />
                                            </Border>
                                            <Border Style="{StaticResource HeroChip}">
                                                <TextBlock Text=".NET 10" Foreground="White" FontSize="12" />
                                            </Border>
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- BODY -->
                        <StackPanel Margin="32,22,32,26">
                            <TextBlock TextWrapping="Wrap" LineHeight="20"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       Text="Claude Code Tray draws your rate-limit usage as a crisp, DPI-aware icon that lives only in the Windows tray — the session (5h), week (7d) and extra windows, with a burn-rate projection that warns before you run out. It's free, open source, and made by the community." />

                            <!-- Quick links — clickable cards (URL in each card's Tag). -->
                            <TextBlock Text="Project &amp; links"
                                       FontSize="16" FontWeight="SemiBold" Margin="0,22,0,12"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />

                            <UniformGrid Columns="2" Margin="-6,0,-6,0">
                                <Border Style="{StaticResource LinkCard}" Margin="6"
                                        MouseLeftButtonUp="Link_Click"
                                        Tag="https://github.com/alegauss/claude-tray">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🐙" FontSize="22" VerticalAlignment="Center" Margin="0,0,12,0" />
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="GitHub repository" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                            <TextBlock Text="Source, README &amp; docs" FontSize="12"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource LinkCard}" Margin="6"
                                        MouseLeftButtonUp="Link_Click"
                                        Tag="https://github.com/alegauss/claude-tray/releases">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="📦" FontSize="22" VerticalAlignment="Center" Margin="0,0,12,0" />
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="Releases" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                            <TextBlock Text="Downloads &amp; changelog" FontSize="12"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource LinkCard}" Margin="6"
                                        MouseLeftButtonUp="Link_Click"
                                        Tag="https://github.com/alegauss/claude-tray/issues/new">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🐛" FontSize="22" VerticalAlignment="Center" Margin="0,0,12,0" />
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="Report an issue" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                            <TextBlock Text="Bugs &amp; feature ideas" FontSize="12"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource LinkCard}" Margin="6"
                                        MouseLeftButtonUp="Link_Click"
                                        Tag="https://github.com/alegauss/claude-tray">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="⭐" FontSize="22" VerticalAlignment="Center" Margin="0,0,12,0" />
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="Star the project" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                            <TextBlock Text="Open the repo and click ★" FontSize="12"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </UniformGrid>

                            <!-- Get involved -->
                            <TextBlock Text="Get involved"
                                       FontSize="16" FontWeight="SemiBold" Margin="0,22,0,12"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />

                            <Border CornerRadius="10" Padding="18,16"
                                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                    BorderThickness="1"
                                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}">
                                <StackPanel>
                                    <TextBlock TextWrapping="Wrap"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                               Text="This is an open-source community project — pull requests, bug reports and ideas are all welcome." />
                                    <StackPanel Margin="0,12,0,0">
                                        <TextBlock Margin="0,0,0,6" TextWrapping="Wrap"
                                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                   Text="⭐  Star the repo to follow new releases" />
                                        <TextBlock Margin="0,0,0,6" TextWrapping="Wrap"
                                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                   Text="🐛  Open an issue for any bug or feature idea" />
                                        <TextBlock Margin="0,0,0,6" TextWrapping="Wrap"
                                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                   Text="🔧  Fork it, run &quot;dotnet build&quot;, and send a pull request" />
                                        <TextBlock TextWrapping="Wrap"
                                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                   Text="📖  Read the README for the architecture notes" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Unofficial / community disclaimer (mirrors the README). -->
                            <TextBlock Margin="2,18,2,0" TextWrapping="Wrap" FontSize="11"
                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                       Text="Unofficial community project — not affiliated with, endorsed by, or sponsored by Anthropic. &quot;Claude&quot; and &quot;Claude Code&quot; are trademarks of Anthropic. Released under the MIT License." />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- ===== Footer (shared) ===== -->
            <Grid Grid.Row="1" Margin="32,12,32,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" x:Name="VersionText"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="CancelButton" Content="Cancel"
                            MinWidth="92" Padding="14,6" Margin="0,0,8,0"
                            Click="Cancel_Click" />
                    <Button x:Name="SaveButton" Content="Save"
                            MinWidth="92" Padding="14,6"
                            Style="{DynamicResource AccentButtonStyle}"
                            Click="Save_Click" />
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Window>
